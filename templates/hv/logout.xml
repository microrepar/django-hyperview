<!--
  Tela de Logout.
  GET: exibe confirmacao. POST: executa logout.
-->
{% extends "hv/base.xml" %}

{% block styles %}
  <style id="flex-1" flex="1" />
  <style id="logout-container" flex="1" justifyContent="center" padding="24" />
  <style id="logout-icon" fontSize="64" textAlign="center" marginBottom="16" />
  <style id="logout-title" color="#1e293b" fontSize="20" fontWeight="bold" textAlign="center" marginBottom="8" />
  <style id="logout-subtitle" color="#64748b" fontSize="14" textAlign="center" marginBottom="24" />
  <style id="success-message" color="#22c55e" fontSize="16" fontWeight="500" textAlign="center" padding="24" />
  <style
    id="btn-primary"
    backgroundColor="#3b82f6"
    borderRadius="12"
    flexDirection="row"
    justifyContent="center"
    margin="16"
    padding="16"
  >
    <modifier pressed="true">
      <style opacity="0.8" />
    </modifier>
  </style>
  <style id="btn-primary-label" color="white" fontSize="16" fontWeight="600" />
  <style
    id="btn-danger"
    backgroundColor="#ef4444"
    borderRadius="12"
    flexDirection="row"
    justifyContent="center"
    margin="16"
    padding="16"
  >
    <modifier pressed="true">
      <style opacity="0.8" />
    </modifier>
  </style>
  <style id="btn-danger-label" color="white" fontSize="16" fontWeight="600" />
  <style
    id="btn-secondary"
    backgroundColor="#e2e8f0"
    borderRadius="12"
    flexDirection="row"
    justifyContent="center"
    margin="16"
    padding="16"
  >
    <modifier pressed="true">
      <style opacity="0.8" />
    </modifier>
  </style>
  <style id="btn-secondary-label" color="#475569" fontSize="16" fontWeight="600" />
{% endblock %}

{% block container %}
  <view scroll="true" flex="1">
  <view style="logout-container">
    {% if logged_out %}
    <text style="logout-icon">👋</text>
    <text style="success-message">Voce saiu da conta.</text>
    <view style="btn-primary">
      <behavior trigger="press" action="navigate" href="#tab-home" />
      <text style="btn-primary-label">Ir para Home</text>
    </view>
    {% else %}
    <text style="logout-icon">🚪</text>
    <text style="logout-title">Sair da conta</text>
    <text style="logout-subtitle">Tem certeza que deseja sair?</text>

    <form id="logout-form">
      <view style="btn-danger" id="logout-button">
        <behavior
          trigger="press"
          action="replace"
          href="{{ base_url }}{% url 'hv:logout' %}"
          verb="POST"
          target="logout-form"
          show-during-load="logout-spinner"
          hide-during-load="logout-button"
        />
        <text style="btn-danger-label">Sim, sair</text>
      </view>
      <spinner id="logout-spinner" hide="true" />
    </form>

    <view style="btn-secondary">
      <behavior trigger="press" action="back" href="#" />
      <text style="btn-secondary-label">Cancelar</text>
    </view>
    {% endif %}
  </view>
  </view>
{% endblock %}
