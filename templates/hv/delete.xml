<!--
  Tela de Confirmacao de Exclusao.
  GET: exibe confirmacao. POST: executa exclusao.
-->
{% extends "hv/base.xml" %}

{% block styles %}
  <style id="flex-1" flex="1" />
  <style id="delete-container" flex="1" justifyContent="center" padding="24" />
  <style id="delete-icon" fontSize="64" textAlign="center" marginBottom="16" />
  <style id="delete-title" color="#1e293b" fontSize="20" fontWeight="bold" textAlign="center" marginBottom="8" />
  <style id="delete-subtitle" color="#64748b" fontSize="14" textAlign="center" marginBottom="24" />
  <style id="success-message" color="#22c55e" fontSize="16" fontWeight="500" textAlign="center" padding="24" />
  <style
    id="btn-primary"
    backgroundColor="#3b82f6"
    borderRadius="12"
    flexDirection="row"
    justifyContent="center"
    margin="16"
    padding="16"
  >
    <modifier pressed="true">
      <style opacity="0.8" />
    </modifier>
  </style>
  <style id="btn-primary-label" color="white" fontSize="16" fontWeight="600" />
  <style
    id="btn-danger"
    backgroundColor="#ef4444"
    borderRadius="12"
    flexDirection="row"
    justifyContent="center"
    margin="16"
    padding="16"
  >
    <modifier pressed="true">
      <style opacity="0.8" />
    </modifier>
  </style>
  <style id="btn-danger-label" color="white" fontSize="16" fontWeight="600" />
  <style
    id="btn-secondary"
    backgroundColor="#e2e8f0"
    borderRadius="12"
    flexDirection="row"
    justifyContent="center"
    margin="16"
    padding="16"
  >
    <modifier pressed="true">
      <style opacity="0.8" />
    </modifier>
  </style>
  <style id="btn-secondary-label" color="#475569" fontSize="16" fontWeight="600" />
{% endblock %}

{% block container %}
  <view scroll="true" flex="1">
  <view style="delete-container">
    {% if deleted %}
    <text style="delete-icon">✅</text>
    <text style="success-message">Item "{{ item.name }}" excluido com sucesso!</text>
    <view style="btn-primary">
      <behavior trigger="press" action="close" href="#" />
      <text style="btn-primary-label">OK</text>
    </view>
    {% else %}
    <text style="delete-icon">🗑️</text>
    <text style="delete-title">Excluir {{ item.name }}</text>
    <text style="delete-subtitle">Tem certeza que deseja excluir este item? Esta acao nao pode ser desfeita.</text>

    <form id="delete-form">
      <view style="btn-danger" id="delete-button">
        <behavior
          trigger="press"
          action="replace"
          href="{{ base_url }}{% url 'hv:detail_delete' item.id %}"
          verb="POST"
          target="delete-form"
          show-during-load="delete-spinner"
          hide-during-load="delete-button"
        />
        <text style="btn-danger-label">Sim, excluir</text>
      </view>
      <spinner id="delete-spinner" hide="true" />
    </form>

    <view style="btn-secondary">
      <behavior trigger="press" action="close" href="#" />
      <text style="btn-secondary-label">Cancelar</text>
    </view>
    {% endif %}
  </view>
  </view>
{% endblock %}
