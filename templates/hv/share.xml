<!--
  Tela de Compartilhamento de um item.
-->
{% extends "hv/base.xml" %}

{% block styles %}
  <style id="flex-1" flex="1" />
  <style id="share-container" flex="1" justifyContent="center" padding="24" />
  <style id="share-icon" fontSize="64" textAlign="center" marginBottom="16" />
  <style id="share-title" color="#1e293b" fontSize="20" fontWeight="bold" textAlign="center" marginBottom="8" />
  <style id="share-subtitle" color="#64748b" fontSize="14" textAlign="center" marginBottom="24" />
  <style id="share-url" backgroundColor="#f1f5f9" borderRadius="8" color="#334155" fontSize="13" padding="12" textAlign="center" />
  <style
    id="btn-primary"
    backgroundColor="#3b82f6"
    borderRadius="12"
    flexDirection="row"
    justifyContent="center"
    margin="16"
    padding="16"
  >
    <modifier pressed="true">
      <style opacity="0.8" />
    </modifier>
  </style>
  <style id="btn-primary-label" color="white" fontSize="16" fontWeight="600" />
{% endblock %}

{% block container %}
  <view scroll="true" flex="1">
  <view style="share-container">
    <text style="share-icon">📤</text>
    <text style="share-title">Compartilhar {{ item.name }}</text>
    <text style="share-subtitle">Copie o link abaixo para compartilhar este item</text>

    <view style="share-url">
      <text>{{ share_url }}</text>
    </view>

    <view style="btn-primary">
      <behavior trigger="press" action="back" href="#" />
      <text style="btn-primary-label">Voltar</text>
    </view>
  </view>
  </view>
{% endblock %}
