# ai-jail sandbox configuration
# https://github.com/akitaonrails/ai-jail
# Edit freely. Regenerate with: ai-jail --clean --init

command = ["pi"]
rw_maps = [
    "/home/mcsilva/.zai/",
    "/home/mcsilva/.claude.json",
    "/home/mcsilva/.pi/",
]
ro_maps = ["/home/mcsilva/Workspaces/hyperview"]
hide_dotdirs = []
mask = []
no_docker = false
allow_tcp_ports = []
