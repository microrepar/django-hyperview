{
  "version": 1,
  "defaultEffect": "allow",
  "rules": [
    {
      "id": "protect-repository-core",
      "effect": "require_approval",
      "when": {
        "paths": [
          "manage.py"
        ],
        "risk": "high"
      },
      "reason": "High-risk changes to core javascript django paths require approval."
    },
    {
      "id": "protect-repository-config",
      "effect": "require_approval",
      "when": {
        "paths": [
          "Dockerfile",
          "docker-compose.yml",
          "pyproject.toml",
          "requirements.txt"
        ],
        "risk": "high"
      },
      "reason": "High-risk changes to repository automation and build configuration require approval."
    },
    {
      "id": "block-secrets",
      "effect": "deny",
      "when": {
        "paths": [
          "**/.env*",
          "**/*.pem",
          "**/*.key",
          "**/*secret*"
        ]
      },
      "reason": "Secret-like files are blocked by policy."
    }
  ]
}
